{
  "ConnectionStrings": {
    "ControlPlane": "Server=localhost;Database=LiveSync_ControlPlane;Trusted_Connection=True;TrustServerCertificate=True;",
    "Legacy": "Server=localhost;Database=LiveSyncDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Tenancy": {
    "DatabaseNamePrefix": "LiveSync_Tenant_",
    "ConnectionTemplate": "Server=localhost;Database={DatabaseName};Trusted_Connection=True;TrustServerCertificate=True;",
    "MigrateFromSharedDatabase": false,
    "LegacyDatabaseName": "LiveSyncDb"
  },
  "Auth": {
    "RequireAuthentication": false,
    "Jwt": {
      "Authority": "LiveSync",
      "Audience": "LiveSync",
      "SecretKey": "local-dev-signing-key-change-me-min-32-chars",
      "ValidateIssuer": true,
      "ValidateAudience": true
    },
    "Development": {
      "AllowAnonymous": false,
      "AllowHeaderFallback": true,
      "DefaultTenantId": 1,
      "DefaultUserId": 1,
      "DefaultUserName": "dev-user"
    }
  }
}
