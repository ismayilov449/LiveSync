{
  "ConnectionStrings": {
    "ControlPlane": "Server=localhost,1433;Database=LiveSync_ControlPlane;User Id=sa;Password=Your_password123;TrustServerCertificate=True;",
    "Legacy": "Server=localhost,1433;Database=LiveSyncDb;User Id=sa;Password=Your_password123;TrustServerCertificate=True;",
    "Redis": "localhost:6379,abortConnect=false"
  },
  "Tenancy": {
    "DatabaseNamePrefix": "LiveSync_Tenant_",
    "ConnectionTemplate": "Server=localhost,1433;Database={DatabaseName};User Id=sa;Password=Your_password123;TrustServerCertificate=True;",
    "MigrateFromSharedDatabase": false,
    "LegacyDatabaseName": "LiveSyncDb",
    "ControlPlaneDatabaseName": "LiveSync_ControlPlane"
  },
  "Auth": {
    "ApiKey": "",
    "RequireAuthentication": true,
    "Jwt": {
      "Authority": "LiveSync",
      "Audience": "LiveSync",
      "SecretKey": "",
      "ValidateIssuer": true,
      "ValidateAudience": true
    },
    "Claims": {
      "TenantId": "tenant_id",
      "UserId": "user_id",
      "UserName": "preferred_username"
    },
    "Development": {
      "AllowAnonymous": false,
      "AllowHeaderFallback": false,
      "DefaultTenantId": 1,
      "DefaultUserId": 1,
      "DefaultUserName": "dev-user"
    }
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5252", "http://localhost:5173" ]
  },
  "Hosting": {
    "ApplyMigrationsOnStartup": false,
    "RunChangeDetection": false,
    "RunSubscriptionExpiry": false
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ChangeDetection": {
    "Enabled": false,
    "PollIntervalMs": 1000,
    "QueueVersion": "1",
    "DistributedLockName": "livesync-change-detection",
    "LockExpirySeconds": 30,
    "ClaimStaleAfterSeconds": 300,
    "MaxRetries": 5,
    "BatchSize": 50,
    "SubscriptionTtlSeconds": 300,
    "ExpiryScanIntervalMs": 60000
  },
  "Observability": {
    "EnablePrometheus": true,
    "Otlp": {
      "Endpoint": "http://localhost:4317"
    }
  },
  "RateLimiting": {
    "TenantPermitLimit": 200,
    "TenantWindowSeconds": 60
  },
  "AllowedHosts": "*"
}
