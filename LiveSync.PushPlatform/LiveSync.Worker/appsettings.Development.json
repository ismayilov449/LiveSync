{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=LiveSyncDb;Trusted_Connection=True;TrustServerCertificate=True;",
    "Redis": "localhost:6379,abortConnect=false"
  },
  "ChangeDetection": {
    "Enabled": true,
    "PollIntervalMs": 1000,
    "QueueVersion": "1",
    "DistributedLockName": "livesync-change-detection"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}